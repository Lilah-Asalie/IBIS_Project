    "cbpm = xr.open_dataset('/Users/steviewalker/Documents/Bloom_Raiders/Data/satellite_data/MODIS.L3m_8D_cbpm2_1080x2160_subset_entire_SO.nc')['npp'].max(dim = 'time')/100#convert to gC / m2/ yr\n",
